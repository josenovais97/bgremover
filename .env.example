# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust for your environment.
# `.env` is git-ignored and must never be committed.
# ---------------------------------------------------------------------------

# Generate a new key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string

# Development: True. Production: False.
DEBUG=True

# Comma-separated hostnames. Required when DEBUG=False.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins (with scheme). Required for HTTPS + CSRF in prod.
# CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Absolute site URL, used for canonical tags and the sitemap.
SITE_URL=http://localhost:8000

# Optional database (defaults to local SQLite). Only needed for the admin.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# In production, set to False only if TLS is terminated elsewhere.
# SECURE_SSL_REDIRECT=True
