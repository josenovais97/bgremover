<?xml version="1.0" encoding="UTF-8"?>
{% comment %}A page with a real Portuguese translation is listed once per language, and both
entries declare the full set of xhtml:link alternates — Google treats a page that only
names its siblings from one side as unlinked. A page that renders English under /pt/ is
listed once, in English, with no alternates: advertising it would claim a translation
that does not exist and submit a near-duplicate for indexing. See TRANSLATED_PATHS.{% endcomment %}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:xhtml="http://www.w3.org/1999/xhtml">
{% for url in urls %}  <url>
    <loc>{{ url.loc }}</loc>
{% if url.alt_pt %}    <xhtml:link rel="alternate" hreflang="en" href="{{ url.alt_en }}"/>
    <xhtml:link rel="alternate" hreflang="pt" href="{{ url.alt_pt }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ url.alt_en }}"/>
{% endif %}    <lastmod>{{ url.lastmod }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>{{ url.priority }}</priority>
  </url>
{% endfor %}</urlset>
